# Database (Azure SQL Server)
# Format: mssql+aioodbc://user:pass@server.database.windows.net:1433/dbname?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no
DATABASE_URL=mssql+aioodbc://user:pass@server.database.windows.net:1433/dbname?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no

# Azure Blob Storage
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=PLACEHOLDER;AccountKey=PLACEHOLDER;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER_NAME=procurement-docs

# Azure Document Intelligence (OCR)
AZURE_DI_ENDPOINT=https://PLACEHOLDER.cognitiveservices.azure.com/
AZURE_DI_KEY=PLACEHOLDER

# Azure OpenAI (ChatGPT 5.4 mini)
AZURE_OPENAI_ENDPOINT=https://PLACEHOLDER.openai.azure.com/
AZURE_OPENAI_KEY=PLACEHOLDER
AZURE_OPENAI_DEPLOYMENT=chatgpt-5.4-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure AI Search (RAG chatbot)
AZURE_SEARCH_ENDPOINT=https://PLACEHOLDER.search.windows.net
AZURE_SEARCH_KEY=PLACEHOLDER
AZURE_SEARCH_INDEX=procurement-docs

# CORS
CORS_ORIGINS=http://localhost:3000

# File upload limits
MAX_FILE_SIZE_MB=20
ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.tiff

# Environment
ENVIRONMENT=development

# Azure Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...;
